# Copy to .env and fill in. Never commit .env (it is gitignored).

# --- Mistral (embedding + generation + RAGAS judge) ---
MISTRAL_API_KEY=

# --- Qdrant Cloud (vector store) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Cohere (rerank, deferred — reserved slot) ---
COHERE_API_KEY=

# --- LangSmith (tracing) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aiact-rag
